{
  "expo": {
    "name": "ARCHIVE-URL",
    "slug": "archive-url",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "scheme": "archiveurl",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.archiveurl.app"
    },
    "android": {
      "package": "com.archiveurl.app"
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3000"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
