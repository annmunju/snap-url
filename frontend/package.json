{
  "name": "archive-url-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "postinstall": "node scripts/patch-expo-header.js",
    "start": "expo start",
    "start:staging": "node scripts/run-expo-with-env.js staging start",
    "start:production": "node scripts/run-expo-with-env.js production start",
    "ios": "expo run:ios",
    "ios:staging": "node scripts/run-expo-with-env.js staging run:ios",
    "ios:production": "node scripts/run-expo-with-env.js production run:ios",
    "android": "expo run:android",
    "android:staging": "node scripts/run-expo-with-env.js staging run:android",
    "android:production": "node scripts/run-expo-with-env.js production run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.1",
    "@hookform/resolvers": "^3.9.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.59.16",
    "dayjs": "^1.11.13",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.577.0",
    "react": "^19.1.0",
    "react-hook-form": "^7.53.1",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.6.3"
  }
}
