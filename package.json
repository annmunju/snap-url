{
  "name": "archive-url-monorepo",
  "private": true,
  "scripts": {
    "build": "echo 'No build step for Python backend'",
    "dev": "python3 backend/run.py",
    "start": "python3 backend/run.py",
    "backend:install": "python3 -m pip install -r backend/requirements.txt",
    "frontend:install": "npm --prefix frontend install",
    "frontend:start": "npm --prefix frontend run start",
    "frontend:ios": "npm --prefix frontend run ios"
  }
}
